<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Task Manager</title>
    
    <link rel="icon" type="image/x-icon" href="~/TaskManagerIcon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="~/TaskManagerIcon.ico" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    
    <style>
        body {
        background-color: #f4f7f6; 
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }
    
    .container { flex: 1; } 

    .card {
        border: none;
        border-radius: 12px;
        transition: transform 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    .input-group-text {
        color: #6c757d;
    }
        .navbar-brand { font-weight: bold; letter-spacing: 1px; }
        body { background-color: #f8f9fa; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Task" asp-action="Index">
                📂 Task Manager
            </a>
        </div>
    </nav>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

 <footer class="footer mt-auto py-4 bg-white border-top shadow-sm">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-3 text-center text-md-start">
                <span class="text-muted small">
                    &copy; 2026 <strong>Task Manager</strong> 
                    <span class="badge bg-primary ms-1">v1.0</span>
                </span>
            </div>
            <div class="col-md-9 text-center text-md-end mt-2 mt-md-0">
                <div class="d-inline-block p-2 rounded-3 bg-light border border-secondary-subtle">
                    <span class="text-dark small fw-semibold">
                        <span class="text-secondary">Rəqəmsal Səhiyyə Mərkəzi</span> seçim mərhələsi üçün <span class="text-primary text-uppercase">ARIF ABDULLA</span> tərəfindən hazırlanmışdır.
                    </span>
                </div>
            </div>
        </div>
    </div>
</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>